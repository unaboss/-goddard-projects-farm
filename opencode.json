{
  "$schema": "https://opencode.ai/config.json",
  "model": "deepseek/deepseek-v4-pro",
  "plugin": ["opencode-chrome-annotation@latest"],
  "provider": {
    "ollama": {
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    },
    "eyesight": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenCode Eyesight (local)",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "groundnext-vision": {
          "name": "GroundNext 7B Vision",
          "id": "hf.co/mradermacher/GroundNext-7B-V0-GGUF:Q6_K"
        }
      }
    }
  },
  "agent": {
    "vision": {
      "description": "Use when reading or analyzing images, screenshots, or photos. Uses OpenCode Eyesight (local).",
      "mode": "subagent",
      "model": "eyesight/groundnext-vision"
    }
  }
}
