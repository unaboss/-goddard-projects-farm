{
  "$schema": "https://opencode.ai/config.json",
  "model": "deepseek/deepseek-v4-pro",
  "plugin": ["opencode-chrome-annotation@latest"],
  "provider": {
    "ollama": {
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    },
    "eyesight": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenCode Eyesight (local)",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "llama3.2-vision": {
          "name": "Llama 3.2 Vision 11B"
        }
      }
    }
  },
  "agent": {
    "vision": {
      "description": "Use when reading or analyzing images, screenshots, or photos. Uses OpenCode Eyesight (local).",
      "mode": "subagent",
      "model": "eyesight/llama3.2-vision"
    }
  }
}
